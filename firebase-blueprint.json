{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential client inquiry from the website.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead." },
        "email": { "type": "string", "format": "email", "description": "Email address." },
        "phone": { "type": "string", "description": "Phone number." },
        "legalIssue": { "type": "string", "description": "Description of the legal problem." },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"], "description": "Current status of the lead." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was submitted." }
      },
      "required": ["name", "email", "phone", "legalIssue", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Admin user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "staff"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Callback": {
      "title": "Callback",
      "description": "A quick callback request from the website.",
      "type": "object",
      "properties": {
        "phone": { "type": "string", "description": "Phone number to call back." },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"], "description": "Current status of the callback request." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was submitted." }
      },
      "required": ["phone", "status", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of client leads."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin user profiles."
    },
    "/callbacks/{callbackId}": {
      "schema": "Callback",
      "description": "Quick callback requests."
    }
  }
}
